<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Description>The Cirreum Distributed caching implementation for Conductor Cacheable Queries.</Description>
		<PackageTags>cirreum;conductor;cache;cqrs</PackageTags>
	</PropertyGroup>

	<ItemGroup>
		<!-- Code-first cache provider: references Cirreum.Domain for AddCacheService + the cache
		     abstractions (ICacheService / CacheExpirationPolicy). Contracts/Kernel flow transitively via Domain. -->
		<PackageReference Include="Cirreum.Domain" Version="1.2.7" />
		<PackageReference Include="Microsoft.Extensions.Caching.Abstractions" Version="10.0.10" />
	</ItemGroup>

	<ItemGroup>
		<Using Include="Cirreum.Caching" />
	</ItemGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="Cirreum.Cache.Distributed.Tests" />
	</ItemGroup>

</Project>